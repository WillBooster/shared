{
  "name": "willbooster-shared",
  "version": "0.0.0-semantically-released",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/shared.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "prepare": "lefthook install || true && bun run --cwd 'packages/wb' build",
    "release": "node scripts/prepareNpmCompatibleRelease.mjs && bun multi-semantic-release --debug",
    "test": "bun wb test",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "overrides": {
    "@types/glob": "8.1.0"
  },
  "devDependencies": {
    "@anolilab/multi-semantic-release": "4.4.1",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/bun": "1.3.14",
    "@types/node": "25.6.0",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "@willbooster/shared-lib": "workspace:*",
    "@willbooster/shared-lib-node": "workspace:*",
    "@willbooster/wb": "workspace:*",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2001",
    "semantic-release": "25.0.3",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2"
  },
  "engines": {
    "node": ">= 22.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
