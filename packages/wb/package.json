{
  "name": "@willbooster/wb",
  "version": "0.0.0-semantically-released",
  "description": "CLI tool for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/shared.git",
    "directory": "packages/wb"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "bin": "bin/index.js",
  "files": [
    "bin/",
    "docker/",
    "dist/"
  ],
  "scripts": {
    "build": "bun run start buildIfNeeded --command 'bun build-ts app'",
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "start": "build-ts run src/index.ts --",
    "start-prod": "bun run build && bun wb",
    "test": "bun wb test",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "fast-glob": "3.3.3",
    "fastest-levenshtein": "1.0.16",
    "globby": "16.2.0",
    "jsonc-parser": "3.3.1",
    "kill-port": "2.0.1",
    "minimal-promise-pool": "6.0.2",
    "semver": "7.8.5",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/babel__core": "7.20.5",
    "@types/bun": "1.3.14",
    "@types/kill-port": "2.0.3",
    "@types/node": "25.6.0",
    "@types/semver": "7.7.1",
    "@types/yargs": "17.0.35",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "at-decorators": "7.1.0",
    "build-ts": "18.0.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "rolldown": "1.0.0-rc.18",
    "sort-package-json": "4.0.0",
    "type-fest": "5.6.0",
    "typescript": "7.0.2",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">= 22.18.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
