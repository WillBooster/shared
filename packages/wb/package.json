{
  "name": "@willbooster/wb",
  "version": "0.0.0-semantically-released",
  "description": "CLI tool for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/shared.git",
    "directory": "packages/wb"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "bin": "bin/index.js",
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "build": "yarn start buildIfNeeded --command 'yarn build-ts app'",
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn prettify",
    "lint": "eslint --color",
    "lint-fix": "yarn lint --fix",
    "prettify": "prettier --cache --color --write \"**/{.*/,}*.{cjs,css,cts,htm,html,java,js,json,json5,jsonc,jsx,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}\" \"!**/test{-,/}fixtures/**\" || true",
    "start": "build-ts run src/index.ts --",
    "start-prod": "yarn build && yarn wb",
    "test": "WB_ENV=test vitest run test",
    "typecheck": "tsc --noEmit",
    "verify-code": "yarn workspace @willbooster/wb start --working-dir \"$INIT_CWD\" verify-code",
    "verify-code-with-tests": "yarn verify-code && yarn test"
  },
  "prettier": "@willbooster/prettier-config",
  "dependencies": {
    "chalk": "5.6.2",
    "dotenv": "17.3.1",
    "dotenv-expand": "12.0.3",
    "globby": "16.1.1",
    "kill-port": "2.0.1",
    "minimal-promise-pool": "6.0.1",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/eslint": "9.6.1",
    "@types/kill-port": "2.0.3",
    "@types/micromatch": "4.0.10",
    "@types/node": "25.5.2",
    "@types/yargs": "17.0.35",
    "@willbooster/eslint-config-ts": "11.5.1",
    "@willbooster/prettier-config": "10.4.0",
    "at-decorators": "7.0.2",
    "build-ts": "17.0.22",
    "eslint": "^9",
    "eslint-config-flat-gitignore": "2.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-sort-class-members": "1.21.0",
    "eslint-plugin-sort-destructure-keys": "3.0.0",
    "eslint-plugin-unicorn": "64.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "micromatch": "4.0.8",
    "prettier": "3.8.1",
    "prettier-plugin-java": "2.8.1",
    "sort-package-json": "3.6.1",
    "type-fest": "5.4.4",
    "typescript": "^5",
    "typescript-eslint": "8.58.0",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">= 18"
  },
  "publishConfig": {
    "access": "public"
  }
}
