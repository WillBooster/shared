{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "./src"
  },
  "exclude": ["src/**/__tests__/**/*", "src/**/*.test.*", "src/**/*.spec.*", "test/**/*", "tests/**/*"],
  "extends": "./tsconfig.json",
  "include": ["src/**/*"]
}
