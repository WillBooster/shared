{
  "name": "@willbooster/shared-lib-blitz-next",
  "version": "0.0.0-semantically-released",
  "description": "Shared library for WillBooster Blitz.js projects",
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/shared.git",
    "directory": "packages/shared-lib-blitz-next"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    },
    "./src": {
      "types": "./src/index.ts",
      "require": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "build-ts lib",
    "check-all-for-ai": "yarn check-for-ai && yarn test",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null 2> /dev/null || true && yarn typecheck && yarn lint-fix --quiet",
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn format-code && yarn prettify",
    "format-code": "oxfmt --write --no-error-on-unmatched-pattern -c \"$(node -e 'console.log(require.resolve(\"@willbooster/oxfmt-config/.oxfmtrc.json\"))')\" .",
    "lint": "oxlint .",
    "lint-fix": "yarn lint --fix",
    "prettify": "prettier --cache --color --no-error-on-unmatched-pattern --write \"**/{.*/,}*.{java}\" \"!**/test{-,/}fixtures/**\" || true",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "verify-code": "yarn workspace @willbooster/wb start --working-dir \"$INIT_CWD\" verify-code",
    "verify-code-with-tests": "yarn verify-code && yarn test"
  },
  "devDependencies": {
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/node": "25.5.2",
    "@willbooster/oxfmt-config": "1.1.0",
    "@willbooster/oxlint-config": "1.3.0",
    "@willbooster/prettier-config": "10.4.0",
    "blitz": "3.0.2",
    "build-ts": "17.0.22",
    "oxfmt": "0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "prettier": "3.8.1",
    "prettier-plugin-java": "2.8.1",
    "sort-package-json": "3.6.1",
    "typescript": "^5.9.3",
    "vitest": "4.0.18"
  },
  "prettier": "@willbooster/prettier-config"
}
