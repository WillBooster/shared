{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "declaration": true,
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "@willbooster/shared-lib/src": ["../shared-lib/src/index.ts"],
      "@willbooster/shared-lib-node/src": ["../shared-lib-node/src/index.ts"]
    },
    "resolveJsonModule": true,
    "rewriteRelativeImportExtensions": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "types": ["node", "jest", "vitest/globals"],
    "verbatimModuleSyntax": true
  },
  "exclude": ["test/fixtures", "packages/*/test/fixtures"],
  "extends": ["@tsconfig/node-lts/tsconfig.json", "@tsconfig/node-ts/tsconfig.json"],
  "include": ["scripts/**/*", "src/**/*", "test/**/*"]
}
